---
export interface Props {
  range: string;
  current?: boolean;
  role: string;
  company: string;
  location?: string;
  focus?: string[];
  stack?: string[];
}
const { range, current = false, role, company, location, focus = [], stack = [] } = Astro.props as Props;
---
<li class="entry">
  <div class="entry-rail" aria-hidden="true"><span class={current ? 'dot current' : 'dot'}></span></div>
  <div class="entry-body">
    <div class="entry-range">{range}{current && <span class="now-pill">now</span>}</div>
    <h3 class="entry-role">{role}</h3>
    <div class="entry-company">{company}{location ? ` · ${location}` : ''}</div>
    <div class="entry-desc"><slot /></div>
    {(focus.length > 0 || stack.length > 0) && (
      <div class="entry-meta">
        {focus.length > 0 && <div><span class="k">focus</span>{focus.join(' · ')}</div>}
        {stack.length > 0 && <div><span class="k">stack</span>{stack.join(' · ')}</div>}
      </div>
    )}
  </div>
</li>

<style>
  .entry { display: grid; grid-template-columns: 16px 1fr; gap: 18px; padding: 0 0 30px; }
  .entry-rail { position: relative; }
  .entry-rail::before {
    content: ""; position: absolute; left: 7px; top: 6px; bottom: -30px; width: 1px; background: var(--hairline);
  }
  .entry:last-child .entry-rail::before { display: none; }
  .dot {
    position: absolute; left: 2px; top: 5px; width: 11px; height: 11px; border-radius: 50%;
    background: var(--paper); border: 1.5px solid var(--ink-muted);
  }
  .dot.current { border-color: var(--ink); background: var(--ink); }

  .entry-range {
    font-family: var(--font-mono); font-size: 12px; letter-spacing: 0.04em; color: var(--ink-muted);
    display: flex; align-items: center; gap: 8px;
  }
  .now-pill {
    font-size: 9.5px; letter-spacing: 0.08em; text-transform: uppercase;
    color: var(--paper); background: var(--ink); border-radius: 4px; padding: 1px 6px;
  }
  .entry-role { margin: 4px 0 2px; font-size: 1.25rem; }
  .entry-company { color: var(--ink-body); font-size: 0.98rem; }
  .entry-desc { margin: 10px 0 0; color: var(--ink-body); font-size: 0.97rem; line-height: 1.65; }
  .entry-desc :global(p) { margin: 0; }
  .entry-meta {
    margin-top: 12px; display: flex; flex-direction: column; gap: 4px;
    font-family: var(--font-mono); font-size: 12px; color: var(--ink-muted);
  }
  .entry-meta .k {
    display: inline-block; min-width: 52px; color: var(--ink-muted); opacity: 0.7;
  }
</style>
