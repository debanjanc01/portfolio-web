  <div class="rows" style="margin-top:24px">
    <div class="row">
      <a class="row-title" href="mailto:debanjanc01@gmail.com">debanjanc01@gmail.com</a>
      <span class="row-meta">email</span>
    </div>
    <div class="row">
      <a class="row-title" href="https://github.com/debanjanc01" target="_blank" rel="noreferrer">@debanjanc01</a>
      <span class="row-meta">github</span>
    </div>
    <div class="row">
      <a class="row-title" href="https://www.linkedin.com/in/debanjanc01" target="_blank" rel="noreferrer">/in/debanjanc01</a>
      <span class="row-meta">linkedin</span>
    </div>
    <div class="row">
      <a class="row-title" href="https://x.com/theybanjan" target="_blank" rel="noreferrer">@theybanjan</a>
