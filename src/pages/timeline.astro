---
import BaseLayout from "../layouts/Base.astro";
import TimelineEvent from "../components/TimelineEvent.astro";
import { getCollection } from 'astro:content';
const entries = (await getCollection('timeline')).sort((a, b) => (b.data.start > a.data.start ? 1 : -1));

const fmt = (d: Date) => `${d.getFullYear()}`;
---

<BaseLayout
  title="Timeline — Debanjan"
  description="Career timeline: 8+ years of backend engineering across production systems, email infrastructure, and distributed systems."
>
  <div class="eyebrow">Career</div>
  <hr class="rule" />
  <h1>Timeline</h1>
  <p class="lede">Eight-plus years building and operating backend systems — communication platforms, search and reconciliation, and email infrastructure at scale.</p>

  <ol class="career">
    {await Promise.all(entries.map(async (e) => {
      const start = fmt(e.data.start);
      const end = e.data.end ? fmt(e.data.end) : 'present';
      const { Content } = await e.render();
      return (
        <TimelineEvent
          range={start === end ? start : `${start} — ${end}`}
          current={!e.data.end}
          role={e.data.role}
          company={e.data.company}
          location={e.data.location}
          focus={e.data.focus}
          stack={e.data.stack}
        >
          <Content />
        </TimelineEvent>
      );
    }))}
  </ol>
</BaseLayout>

<style>
  .career { list-style: none; padding: 0; margin: 32px 0 0; }
</style>
